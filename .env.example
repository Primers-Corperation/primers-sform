# Sovereign Intelligence Platform — Environment Configuration
# Copy to .env and configure before deployment

# Deployment mode
SOVEREIGN_MODE=true
VERCEL=false

# Model paths (mount weights here for full inference)
BERT_TRIAGE_PATH=./models/bert_triage
DAN_QWEN_PATH=./models/dan_qwen
DETR_VISION_PATH=./models/detr_vision
WHISPER_VOICE_PATH=./models/whisper_voice

# Data persistence
SIP_DATA_DIR=/tmp/sip_data

# Security — CHANGE THESE BEFORE OPERATIONAL DEPLOYMENT
SIP_SECRET_KEY=sovereign-secret-change-this-immediately
